            </tr>
            </thead>
            <tbody>
            {% for source,calls in callsAll %}
                {% for row in calls|batch(2) %}
                    {% for call in row %}
                        <tr>
                            <td>{{ call.start }}</td>
                            <td>{{ call.stop }}</td>
                            <td>{{ call.call_to }}</td>
                            <td>{{ call.source }}</td>
                            <td>{{ call.getFormattedDuration() }}</td>
                            <td>{{ App.financeFormat(call.sell_price, true) }}</td>
                        </tr>
                    {% endfor %}
                {% endfor %}
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endif %}

{% if enableAllMessages %}
    {% set messagesAll = helper.getVoiceMessages() %}
    {% if messagesAll is not empty %}
        <h3 class="decorate-h3-tag">Todos los Mensajes</h3>
        <table class="list">
            <thead>
            <tr>
                <th style="width: 25%">Fecha</th>
                <th style="width: 25%">Destino</th>
                <th style="width: 25%">Monto</th>
                <th style="width: 25%">Precio</th>
            </tr>
            </thead>
            <tbody>
            {% for source,messages in messagesAll %}
                {% for row in messages|batch(2) %}
                    {% for message in row %}
                        <tr>
                            <td>{{ message.send_at }}</td>
                            <td>{{ message.destination }}</td>
                            <td>{{ message.amount }}</td>
                            <td>{{ App.financeFormat(message.sell_price, true) }}</td>
                        </tr>
                    {% endfor %}
                {% endfor %}
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endif %}

{% if enableAllData %}
    {% set dataAll = helper.getVoiceData() %}
    {% if dataAll is not empty %}
        <h3 class="decorate-h3-tag">Total de datos</h3>
        <table class="list">
            <thead>
            <tr>
                <th style="width: 30%">Fecha</th>
                <th style="width: 35%">Monto</th>
                <th style="width: 35%">Precio</th>
            </tr>
            </thead>
            <tbody>
            {% for source,data in dataAll %}
                {% for row in data|batch(2) %}
                    {% for item in row %}
                        <tr>
                            <td>{{ item.datetime}}</td>
                            <td>{{ item.getFormattedAmount() }}</td>
                            <td>{{ App.financeFormat(item.sell_price, true) }}</td>
                        </tr>
                    {% endfor %}
                {% endfor %}
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endif %}

<table>
    <tr>
        <td style="padding: 0px">
            <table class="last">
                <tr>
                    <td>
                        Para<br>
                        <strong>{{ customer.name }}</strong><br>
                        <strong>-----------------------------------------------------------------</strong>
                    </td>
                    <td style="font-size: 24px; vertical-align: bottom; text-align: left; padding-left: 43px">Recibo de Pago</td>
                </tr>
                <tr>
                    <td>
                        <table style="margin: 35 0 0 3; width: 200px">
                            <tr>
                                <td>Factura#</td>
                                <td>:&nbsp;&nbsp;&nbsp;&nbsp;{{ number }}</td>
                            </tr>
                            <tr>
                                <td>Fecha de Factura</td>
                                <td>:&nbsp;&nbsp;&nbsp;&nbsp;{{ date_created | date(date_format) }}</td>
                            </tr>
                            <tr>
                                <td>Adeudo</td>
                                <td>:&nbsp;&nbsp;&nbsp;&nbsp;{{ App.financeFormat(customer_billing.deposit, true) }}</td>
                            </tr>
                        </table>
                    </td>
                    <td></td>
                </tr>
                <tr>
                    <td style="padding: 0px; vertical-align: top;">
                        <table style="width: 232px; margin: 0px; border: 1px solid {{ last_block_line_color }}; border-collapse: collapse;">
                            <tr>
                                <td style="width: 85px; font-size: 11px; padding: 6 0 6 25; border: 1px solid {{ last_block_line_color }}; background: {{ line_color }}">
