<table class="list">
    <thead>
    <tr>
        <th width="6%">#</th>
        <th style="text-align: left">DESCRIPCIÓN DEL ARTÍCULO</th>
        <th>IVA %</th>
        <th>IVA</th>
        <th>MONTO</th>
    </tr>
    </thead>
    <tbody>
    {% for item in items %}
        {% set vat = item.price * item.tax / 100 * item.quantity %}
        {% set total_item = item.price + vat %}
        {% set total_vat = total_vat + vat %}

        <tr>
            <td>{{ item.pos }}</td>
            <td style="text-align: left">{{ item.description }}</td>
            {% if item.tax == 0 %}
                <td>-</td>
            {% else %}
                <td>{{ App.financeFormat(item.tax) }}</td>
            {% endif %}
            {% if vat == 0 %}
                <td>-</td>
            {% else %}
                <td>{{  App.financeFormat(vat) }}</td>
            {% endif %}
            <td>
                {{ App.financeFormat(total_item * item.quantity, true) }}<br>
                <span class="price-desc">{{ item.quantity|number_format(1, '.', ' ') }} x {{ App.financeFormat(total_item) }}</span>
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>

