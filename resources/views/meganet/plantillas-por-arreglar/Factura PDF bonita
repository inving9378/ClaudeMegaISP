</table>

<htmlpagefooter name="footer">
    <table class="footer">
        {% if footer_line == 1 %}
            <tr><td colspan="2" style="background: {{ line_color }}; font-size: 10px;"></td></tr>
        {% endif %}
        <tr>
            <td style="width: 718px">
                {{ footer_text }}
            </td>
            <td style="font-size: 7px; text-align: right; vertical-align: bottom;">{PAGENO}</td>
        </tr>
    </table>
</htmlpagefooter>
</body>
</html>
