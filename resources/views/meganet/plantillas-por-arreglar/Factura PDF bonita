{% set font = 'Arial' %} {# Font of the document #}
{% set main_text_color = '#000000' %} {# Main text color #}
{% set description_text_color = '#817D7D' %} {# Secondary text color for decription #}
{% set table_header_text_color = '#2F81B7' %} {# Text color for table-header and mini-hedear #}
{% set line_color = '#E3E3E3' %} {# Color of the delimeter line in thr table and others #}
{% set last_block_line_color ="#BFBFBF" %} {# Color of last block border #}
{% set background = '#FFFFFF' %} {# Background of page #}
{% set block_background = '#E7F7FE' %} {# Background of blocks description #}

{% set date_format = App.getDateFormat() %} {# Format for view dates #}

{% set text_in_total_block = '' %} {# Text total block #}
{% set terms_and_conditions = '' %} {# Terms & Conditions text #}

{% set header_background_color = "#2F81B7" %}
{% set header_text_color = '#FFFFFF' %}

{% set footer_background_color = "#FFFFFF" %}
{% set footer_text_color = "#233FEC" %}
{% set footer_text = "" %}
{% set footer_line = 0 %} {# Enable/Disable delimeter line on top of footer #}

{# DONT TUCH #}
{% set padding_right = 42 %}
{% set padding_left = 50 %}

{% set total_vat = 0 %}

{# Enabling showing statistics by categories, this block with true or false values only #}
{% set enableCallsStatistics  = true %}
{% set enableMessagesStatistics  = true %}
{% set enableDataStatistics  = true %}

{% set enableStatistic = enableCallsStatistics or enableMessagesStatistics or enableDataStatistics %}

{# Enabling showing detail statistics by type, reflected when statistics are enabled #}
{% set enableDetailCallsStatistics  = true %}
{% set enableDetailMessagesStatistics  = true %}
{% set enableDetailDataStatistics  = true %}

{# Enabling showing about data by type#}
{% set enableAllCalls = true %}
{% set enableAllMessages = true %}
{% set enableAllData = true %}

{% set voiceCategories = loader.getVoiceCategoriesArray() %}
<html>
<head>
    <style type="text/css">
        @page {
            sheet-size: 216mm 279.5mm;
            margin: 60 0 0 0;
            margin-header: 0mm;
            footer: footer;
            margin-bottom: 80px;
            margin-footer: 0mm;
            background: {{ background }};
        }

        .header {
            margin: 0px;
            padding: 0px;
            border: 0px;
            background: {{ header_background_color }};
            width: 100%;
            height: 147px;
            border-collapse: collapse;
            border: 0px;
        }

        .header table {
            height: 100%;
            color: {{ header_text_color }};
        }

        .mini-header {
            width: 100%;
            background: {{ block_background }};
            color: {{ table_header_text_color }};
            text-align: right;
            font-size: 15px;
            padding: 8 53 8 0;
            margin-top: 87px;
        }

        .footer {
            height: 63px;
            margin: 0;
            padding: 0, {{ padding_right }}, 10, {{ padding_left }};
            font-size: 18.3px;
            color: {{ footer_text_color }};
            background: {{ footer_background_color }};
        }

        table {
            width: 100%;
            margin-left: {{ padding_left }}px;
            margin-right: {{ padding_right }}px;
        }

        .page-block {
            width: 100%;
            padding-left: {{ padding_left }}px;
            padding-right: {{ padding_right }}px;
            font-size: 13.5px;
            color: {{ main_text_color }};
            margin-top: 22px;
        }

        .payed-block {
            width: 200px;
            position: absolute;
            top: 190px;
            left: 280px;
        }

        .invoices_info {
            padding: 0;
            margin: 0;
            font-size: 13.3px;
            text-align: right;
            border-collapse: separate;
            border-spacing: 0px 6px;
            height: 100%
        }

        .invoices_info td {
            color: {{ main_text_color }};
        }

        .list {
            margin-top: 18px;
            border-spacing: 19px;
            border-collapse: collapse;
        }

        .list th {
            text-decoration: none;
            font-weight: normal;
            color: {{ table_header_text_color }};
            font-size: 15px;
            padding: 21 0 21 0;
        }

        .list td {
            color: {{ main_text_color }};
            text-align: center;
            border-top: 2px solid {{ line_color }};
            padding: 21 0 21 0;
        }

        .price-desc {
            font-size: 11.5px;
            color: {{ description_text_color }};
        }

        .invoice-total {
            border-spacing: 30px;
            font-size: 12px;
            background: {{ block_background }};
        }

        .invoice-total td {
            width: 50%;
            vertical-align: top;
        }

        .invoice-total table {
            margin: -20, 0, 0, 0;
            border-spacing: 20px;
        }

        .last {
            font-size: 12.5px;
            margin: 0 0 0 -6;
            padding: 0px;
        }

        .last td {
            width: 50%;
        }

        .little-table {
            border-collapse: collapse;
        }

        .little-table th {
            text-decoration: none;
            font-weight: normal;
            color: {{ table_header_text_color }};
            font-size: 12px;
            padding: 12px 0 12px 0;
        }

        .little-table td {
            color: {{ main_text_color }};
            text-align: center;
            border-top: 2px solid {{ line_color }}
        }

        .little-table-inner {
            border-collapse: collapse;
            margin-top: 15px;
        }

        .little-table-inner th {
            text-decoration: none;
            font-weight: normal;
            color: {{ table_header_text_color }};
            font-size: 10px;
            padding: 0;
        }

        .little-table-inner td {
            color: {{ main_text_color }};
            text-align: center;
            font-size: 10px;
            border-top: 0;
        }

        h3.decorate-h3-tag {
            margin-left: 30px;
            color: {{ table_header_text_color }};
        }
        h4.decorate-h4-tag {
            margin-left: 40px;
            color: {{ table_header_text_color }};
        }
    </style>
</head>
