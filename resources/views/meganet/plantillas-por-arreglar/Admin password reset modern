<!DOCTYPE html>
<html lang="en">
<head lang="en">
    <meta charset="UTF-8">
    <title>Request for administrator password reset</title>
</head>
<body>
<div style="background-color: #F7F8FC; color: #1B2124; border-radius: 4px; border: 1px solid #E9ECEF; padding: 24px; font-size: 14px; font-family: Arial, sans-serif; line-height: 20px; width: 600px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 24px;">
        {% if company_info.splynx_url and company_info.file_logo %}
            <img style="max-width: 200px; max-height: 150px;" alt="logo" src="{{ company_info.splynx_url }}{{ company_info.logo_url }}">
        {% else %}
            <p style="color: #1B2124; font-size: 18px; line-height: 24px; font-weight: 600;">{{ company_info.company_name }}</p>
        {% endif %}
    </div>
    <h1 style="color: #1B2124; font-size: 18px; line-height: 24px; font-weight: 600; margin: 12px 0 16px 0;">
        Admin reset password
    </h1>
    <p style="color: #1B2124; margin: 12px 0; line-height: 20px;">
        Hello {{ admin.name }}, you have made a request to change the password.
    </p>
    <p style="color: #1B2124; margin: 12px 0; line-height: 20px;">
        If you do request a password reset, follow the link:
        <a href="{{ domain }}/admin/reset-password--set-new-password?code={{ code }}"
           style="text-decoration: none; color: #367BF5;">Change password</a>
        <br>
        Or use this code: <span style="font-weight: 600;">{{ code }}</span>
        <br>
        On <a href="{{ domain }}/admin/reset-password--verify-check-code"
              style="color: #367BF5!important; text-decoration: none;">this</a> page.
    </p>
    <p style="color: #1B2124; margin: 0; line-height: 20px;">
        In other case, contact the administration.
    </p>
</div>
</body>
</html>
