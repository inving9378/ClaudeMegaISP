<table style="background: #f5f5f5;padding:5px 10px;width:100%;">
    <thead>
    <tr>
        <td style="padding:5px;font-size: 20px;">
            {% if type == 'team' %}
                {{ author.name }} mentioned your team {{ team.title }} on {{ source.name }} <a href="{{ source.link | raw }}" target="_blank">#{{ source.id }}</a>:
            {% elseif type == 'admin' %}
                {{ author.name }} mentioned you on {{ source.name }} <a href="{{ source.link | raw }}" target="_blank">#{{ source.id }}</a>:
            {% endif %}
        </td>
    </tr>
    </thead>
    <tbody>
    <tr>
        <td style="border-left: 2px solid #ccc;padding:10px;background: #fff;">
            <a href="{{ source.link | raw }}" target="_blank" style="font-size: 20px;line-height:30px;color:#3b73af;text-decoration: none;">
                {{ source.title | raw }}
            </a>
            <br>
            {{ text | raw }}
        </td>
    </tr>
    </tbody>
</table>
