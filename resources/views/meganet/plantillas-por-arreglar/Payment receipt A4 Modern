{% set total_vat = 0 %}

{% set enableVoiceDetails  = true %}
{# Enabling showing statistics by categories, this block with true or false values only #}
{% set enableCallsStatistics  = true %}
{% set enableMessagesStatistics  = true %}
{% set enableDataStatistics  = true %}
{% set enableStatistic = enableCallsStatistics or enableMessagesStatistics or enableDataStatistics %}

<html>
<head>
    <style type="text/css">
        @page {
            sheet-size: 209mm 279.5mm;
            margin: 20px 0 0 0;
            margin-header: 0mm;
            footer: footer;
            header: secondpageheader;
            margin-bottom: 80px;
            margin-footer: 0mm;
            border: 0px;
            background: linear-gradient(to right, rgba(250, 250, 250, 1) 36%, rgba(255, 255, 255, 1) 36%, rgba(255, 255, 255, 1) 100%);
        }

        @page :first {
            header: firstpage;
        }


        * {
            box-sizing: border-box;
        }

        .page_holder {
            font-family: 'Helvetica', sans-serif;
            margin: 0 auto;
            padding: 0;
        }

        .header {
            margin: 0;
            padding: 20px 20px;
            width: 100%;
            border: 0;
            text-align: center;
        }

        .header table {
            border-colapse: colapse;
            vertical-align: top;
            border: 0;
            width: 100%;
        }

        .header table td {
            vertical-align: top;
        }

        .header table td.logo {
            text-align: left;
            width: auto;
            padding-bottom: 20px;
        }

        .header table td.line_heading {
            font-family: 'Helvetica', sans-serif;
            font-size: 30px;
            font-weight: bold;
            color: #212121;
            text-align: left;
            text-transform: uppercase;
        }

        .header table td.left_col td {
            font-size: 14px;
            color: #212121;
            font-family: 'Helvetica', sans-serif;
        }

        .header table td.right_col .name,
        .header table td.left_col .name {
            font-size: 16px;
            font-weight: bold;
            color: #212121;
            padding-top: 38px;
            padding-bottom: 7px;
            padding-left: 0;
            padding-right: 0;
            font-family: 'Helvetica', sans-serif;
        }


        .header table td.right_col {
            width: 33%;
            color: #000;
            font-family: 'Helvetica', sans-serif;
        }

        .header table td.right_col table td {
            font-family: 'Helvetica', sans-serif;
            font-size: 14px;
            line-height: 1.4;
            padding: 0;
        }

        .header table td.right_col table td:nth-child(2) {
            text-align: right;
            font-family: 'Helvetica', sans-serif;
        }

        .header table td.right_col table tr.total td {
            font-weight: bold;
            padding-top: 14px;
        }

        .header2 {
            margin: 0;
            padding: 14px 20px;
            width: 100%;
            border: 0;
            text-align: center;
        }

        .header2 .logo {
            display: block;
            text-align: left;
            line-height: 30px;
            margin-right: 16px;
            padding-top: 0px;
        }

        .header2 .header_name2 {
            float: left;
            line-height: 20px;
            font-size: 20px;
            font-weight: normal;
            width: 100%;
            color: #ffffff;
            text-transform: uppercase;
            padding-top: 8px;
            font-family: 'Helvetica', sans-serif;
            text-align: left;
        }

        .clear {
            clear: both;
            width: 100%;
        }

        .page_content {
            padding: 17px 20px 0 20px;
            text-align: center;
        }

        .page_content .right_part table td:nth-child(1) {
            width: 80px;
        }

        .third_line {
            width: 100%;
            padding-top: 18px;
        }

        .invoice-items table {
            border-collapse: collapse;
            width: 100%;
        }

        .invoice-items table th {
            color: #000000;
            font-size: 14px;
            text-align: left;
            font-weight: bold;
            padding: 6px 8px;
            border-top: solid 1px #e0e0e0;
            border-bottom: solid 1px #e0e0e0;
            font-family: 'Helvetica', sans-serif;
        }

        .invoice-items table td {
            color: #000;
            font-size: 12px;
            line-height: 1.6;
            text-align: left;
            font-weight: normal;
            padding: 6px 8px;
            border-bottom: solid 1px #e0e0e0;
            font-family: 'Helvetica', sans-serif;
            vertical-align: middle;
            height: 36px;
        }

        .invoice-items table th:nth-child(1) {
            text-align: left;
        }

        .invoice-items table td:nth-child(2) {
            text-align: left;
            font-style: italic;
        }

        .invoice-items table th:nth-child(1),
        .invoice-items table td:nth-child(1) {
            width: 25px;
        }

        .invoice-items table th:nth-child(3),
        .invoice-items table th:nth-child(4),
        .invoice-items table td:nth-child(3),
        .invoice-items table td:nth-child(4) {
            width: 130px;
            text-align: center;
        }


        .invoice-items table td:nth-child(4) {
            font-weight: bold;
        }

        .invoice_total {
            padding: 20px 16px 20px 0;
        }

        .invoice_total .tables_holder {
            width: 30%;
            float: right;
        }

        .invoice_total .tables_holder table {
            border-collapse: collapse;
            width: 100%;
        }

        .invoice_total .tables_holder table tr td {
            padding-top: 5px;
            font-family: 'Helvetica', sans-serif;
        }

        .invoice_total .tables_holder table tr td:nth-child(1) {
            font-size: 14px;
            line-height: 10px;
            color: #000;
            border-collapse: collapse;
            width: 50%;
        }

        .invoice_total .tables_holder table tr td:nth-child(2) {
            font-size: 14px;
            font-weight: bold;
            text-align: left;
            width: 50%;
        }

        .invoice_total .tables_holder table tr.blue td:nth-child(1),
        .invoice_total .tables_holder table tr.blue td {
            padding-top: 16px;
            font-weight: bold;
            padding-bottom: 15px;
        }

    </style>
</head>
<body>
<htmlpageheader name="firstpage">
    <div class="header">
        <table>
            <tr>
                <td class="left_col">
                    <table>
                        <tr>
                            <td class="logo">
                                <img style="max-height:80px;max-width:250px" src="{{ company_info.getLogoFilePath() }}">
                            </td>
                        </tr>
                    </table>

                </td>
                <td class="right_col">
                    <table>
                        <tr>
                            <td class="line_heading">
                                {{ App.t('invoice','Payment') }}<br>
                                {{ App.t('invoice','receipt') }}
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
            <tr>
                <td class="left_col">
                    <table>
                        <tr>
                            <td class="name">
                                <strong>{{ company_info.company_name }}</strong>
                            </td>
                        </tr>
                        <tr>
                            <td>{{ company_info.street_1 ~ ' ' ~ company_info.street_2 }}</td>
                        </tr>
                        <tr>
                            <td>{{ company_info.city }}</td>
                        </tr>
                        <tr>
                            <td>{{ company_info.zip ~ ', ' ~ company_info.country }}</td>
                        </tr>
                    </table>
                </td>
                <td class="right_col">
                    <table>
                        <tr>
                            <td class="name">{{ customer.name }}</td>
                        </tr>
                        {% if customer.street_1 %}
                            <tr>
                                <td>{{ customer.street_1 }}</td>
                            </tr>
                        {% endif %}
                        {% if customer.city %}
                            <tr>
                                <td>{{ customer.city }}</td>
                            </tr>
                        {% endif %}
                        {% if customer.zip_code %}
                            <tr>
                                <td>{{ customer.zip_code }}</td>
                            </tr>
                        {% endif %}
                    </table>
                </td>
            </tr>
        </table>
    </div>
</htmlpageheader>
<htmlpageheader name="secondpageheader">
    <div class="header2">
        <table>
            <tr>
                <td rowspan="3" class="logo">
                    <img style="max-height:100px;max-width:200px" src="{{ company_info.getLogoFilePath() }}">
                </td>
                <td class="name">
                    <strong>{{ company_info.company_name }}</strong>
                </td>
            </tr>
            <tr>
                <td>{{ company_info.street_1 ~ ' ' ~ company_info.street_2 }}{{ company_info.city }},</td>
            </tr>
            <tr>
                <td>{{ company_info.zip ~ ', ' ~ company_info.country }}</td>
            </tr>
        </table>
    </div>
</htmlpageheader>
<div class="page_holder">
    <div class="page_content">
        <div class="third_line">
            <div class="invoice-items">
                <table>
                    <thead>
                    <tr>
                        <th>#</th>
                        <th>{{ App.t('invoice','Receipt number') }}</th>
                        <th>{{ App.t('invoice','Payment date') }}</th>
                        <th>{{ App.t('invoice','Total') }}</th>
                    </tr>
                    </thead>

                    <tr>
                        <td>1</td>
                        <td>{{ receipt_number }}</td>
                        <td>{{ App.formatDate(date) }}</td>
                        <td>{{ App.financeFormat(amount, true) }}</td>
                    </tr>
                </table>
            </div>

            <div class="invoice_total">
                <div class="tables_holder">
                    <table>
                        <tr class="blue">
                            <td>{{ App.t('invoice','Total') }}:</td>
                            <td>{{ App.financeFormat(amount, true) }}</td>
                        </tr>
                        <tr class="signature">
                            <td>Signature:</td>
                            <td>_______________________</td>
                        </tr>
                    </table>
                </div>
                <div class="clear"></div>
            </div>
        </div>
    </div>
</div>

</body>
</html>
